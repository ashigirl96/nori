    "settings.app.closeWorkspaceOnLastSurfaceShortcut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Workspace Open When Closing Last Surface"
          }
